# ==================== 数据库配置 ====================
# PostgreSQL 数据库连接 URL
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://user:password@localhost:5432/stss

# ==================== JWT 配置 ====================
# JWT 密钥（生产环境必须修改为强随机字符串）
# 建议使用: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# JWT Access Token 过期时间（短时效，用于接口认证）
# 格式: 数字+单位 (s=秒, m=分钟, h=小时, d=天)
JWT_ACCESS_EXPIRES_IN=15m

# JWT Refresh Token 过期时间（长时效，用于刷新 access token）
JWT_REFRESH_EXPIRES_IN=7d

# ==================== 服务器配置 ====================
# 服务器端口
PORT=3000

# 运行环境: development | production | test
NODE_ENV=development

# ==================== CORS 配置 ====================
# 允许的跨域来源（多个用逗号分隔）
CORS_ORIGIN=http://localhost:5173

# ==================== 可选配置 ====================
# 如果使用 SQLite（仅开发环境）
# DATABASE_URL=file:./prisma/dev.db

# 旧版 JWT 过期时间（已废弃，请使用 JWT_ACCESS_EXPIRES_IN）
# JWT_EXPIRES_IN=7d
