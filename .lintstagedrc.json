{
  "$schema": "https://json.schemastore.org/lintstagedrc.json",
  "*.{js,ts,json,md,css,scss}": "prettier --write",
  "backend/**/*.ts": "pnpm --filter @stss/server exec eslint --fix",
  "frontend/**/*.{ts,tsx}": "pnpm --filter frontend exec eslint --fix",
  "backend/prisma/schema.prisma": "cd backend && npx prisma format"
}
