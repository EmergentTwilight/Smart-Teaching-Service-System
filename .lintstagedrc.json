{
  "$schema": "https://json.schemastore.org/lintstagedrc.json",
  "*.{js,ts,json,md,css,scss}": ["prettier --write --ignore-unknown"],
  "backend/**/*.ts": ["sh", "-c", "cd backend && pnpm exec eslint --fix"],
  "frontend/**/*.{ts,tsx}": ["sh", "-c", "cd frontend && pnpm exec eslint --fix"],
  "backend/prisma/schema.prisma": ["sh", "-c", "cd backend && npx prisma format"]
}
